# Production environment file for auth_service.
# Copy to .env.prod and fill in real values — this file IS committed; .env.prod is NOT.

# Application
APP_NAME=Campus Assist Auth Service
DEBUG=False

# Server
HOST=0.0.0.0
PORT=8000

# JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database — use a strong password in production
DATABASE_URL=postgresql://<db-user>:<strong-password>@localhost:5432/<db-name>

# JWT secret — generate with: openssl rand -hex 32
SECRET_KEY=<strong-random-secret>

# Google OAuth
GOOGLE_CLIENT_ID=<your-client-id>.apps.googleusercontent.com
