# Application
APP_NAME=Campus Assist Comment Service
DEBUG=False

# Server
HOST=0.0.0.0
PORT=8003

# Database
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<db>

# JWT — must match SECRET_KEY in auth_service
SECRET_KEY=<your-secret-key>

# Internal service URLs
COMMUNITY_SERVICE_URL=http://community-service:80
POST_SERVICE_URL=http://post-service:80
